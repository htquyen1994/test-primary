# Environment variables — copy to .env and fill in values
# Never commit .env to version control

# Database — SQL Server
DATABASE_URL=mssql+pyodbc://admin:Quyen%40135@localhost:1433/trading?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# Redis
REDIS_URL=redis://localhost:6379/0

# Config file path
CONFIG_PATH=config.yaml

# Exchange API keys (testnet)
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_SECRET=your_testnet_secret

# Dashboard API key — protects confirm/skip/unlock/config-write endpoints
# Set a strong random string (e.g. openssl rand -hex 32)
# Must match VITE_DASHBOARD_API_KEY in the frontend .env.local
# If unset, write endpoints are open (dev mode only)
DASHBOARD_API_KEY=
